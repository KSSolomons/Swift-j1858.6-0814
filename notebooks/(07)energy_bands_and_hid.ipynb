{
 "cells": [
  {
   "metadata": {},
   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# 7. Energy Bands Extraction and Hardness-Intensity Diagram (HID)\\n\",\n",
    "    \"This notebook extracts light curves in different energy bands (soft: 0.5-2 keV, hard: 2-10 keV) using the existing script and then plots the Hardness-Intensity Diagram (HID).\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"from astropy.io import fits\\n\",\n",
    "    \"from astropy.table import Table\\n\",\n",
    "    \"\\n\",\n",
    "    \"# --- USER CONFIGURATION ---\\n\",\n",
    "    \"os.environ['PROJECT_ROOT'] = '/media/kyle/kyle_phd/Swift-j1858.6-0814'\\n\",\n",
    "    \"# No leading slash for obsid here since it's appending to paths without it in your script usually, but we match what was previously un-slashed in your shell scripts.\\n\",\n",
    "    \"os.environ['OBSID'] = '0865600201'\\n\",\n",
    "    \"\\n\",\n",
    "    \"project_root = os.environ.get('PROJECT_ROOT')\\n\",\n",
    "    \"obsid = os.environ.get('OBSID')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Step 1: Extract the energy-resolved light curves\\n\",\n",
    "    \"Run `07_extract_energy_bands_lc.sh` from within the notebook to generate the soft and hard light curves.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"!../scripts/07_extract_energy_bands_lc.sh\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Step 2: Load the light curves and calculate hardness\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"soft_path = f\\\"{project_root}/products/{obsid}/pn/lc/pn_source_lc_corrected_soft.fits\\\"\\n\",\n",
    "    \"hard_path = f\\\"{project_root}/products/{obsid}/pn/lc/pn_source_lc_corrected_hard.fits\\\"\\n\",\n",
    "    \"total_path = f\\\"{project_root}/products/{obsid}/pn/lc/pn_source_lc_corrected.fits\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"with fits.open(soft_path) as hdul_s, fits.open(hard_path) as hdul_h, fits.open(total_path) as hdul_t:\\n\",\n",
    "    \"    t_soft = Table(hdul_s[1].data)\\n\",\n",
    "    \"    t_hard = Table(hdul_h[1].data)\\n\",\n",
    "    \"    t_tot = Table(hdul_t[1].data)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Ensure time arrays are synchronized\\n\",\n",
    "    \"time = t_soft['TIME']\\n\",\n",
    "    \"soft_rate = t_soft['RATE']\\n\",\n",
    "    \"hard_rate = t_hard['RATE']\\n\",\n",
    "    \"tot_rate = t_tot['RATE']\\n\",\n",
    "    \"soft_err = t_soft['ERROR']\\n\",\n",
    "    \"hard_err = t_hard['ERROR']\\n\",\n",
    "    \"tot_err = t_tot['ERROR']\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Clean NaNs\\n\",\n",
    "    \"mask = np.isfinite(soft_rate) & np.isfinite(hard_rate) & np.isfinite(tot_rate) & (soft_rate > 0) & (hard_rate > 0) & (tot_rate > 0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"time_clean = time[mask]\\n\",\n",
    "    \"soft_clean = soft_rate[mask]\\n\",\n",
    "    \"hard_clean = hard_rate[mask]\\n\",\n",
    "    \"tot_clean = tot_rate[mask]\\n\",\n",
    "    \"tot_err_clean = tot_err[mask]\\n\",\n",
    "    \"soft_err_clean = soft_err[mask]\\n\",\n",
    "    \"hard_err_clean = hard_err[mask]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Hardness Ratio (Hard / Soft)\\n\",\n",
    "    \"hardness = hard_clean / soft_clean\\n\",\n",
    "    \"# Error propagation for Hardness\\n\",\n",
    "    \"hardness_err = hardness * np.sqrt((hard_err_clean/hard_clean)**2 + (soft_err_clean/soft_clean)**2)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Step 3: Plot the Hardness Intensity Diagram (HID) and Light Curves\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 6), dpi=100)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Left: Time vs Hardness and Intensity\\n\",\n",
    "    \"color = 'tab:blue'\\n\",\n",
    "    \"ax1.set_xlabel('Time (s)', fontsize=14)\\n\",\n",
    "    \"ax1.set_ylabel('Total Count Rate (c/s)', color=color, fontsize=14)\\n\",\n",
    "    \"ax1.scatter(time_clean - time_clean[0], tot_clean, color=color, alpha=0.5, s=10, label='Intensity')\\n\",\n",
    "    \"ax1.tick_params(axis='y', labelcolor=color)\\n\",\n",
    "    \"\\n\",\n",
    "    \"ax1_2 = ax1.twinx()  \\n\",\n",
    "    \"color = 'tab:orange'\\n\",\n",
    "    \"ax1_2.set_ylabel('Hardness (Hard/Soft)', color=color, fontsize=14)\\n\",\n",
    "    \"ax1_2.scatter(time_clean - time_clean[0], hardness, color=color, alpha=0.5, s=10, label='Hardness')\\n\",\n",
    "    \"ax1_2.tick_params(axis='y', labelcolor=color)\\n\",\n",
    "    \"ax1.set_title(\\\"Lightcurve & Hardness\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Right: HID\\n\",\n",
    "    \"ax2.errorbar(hardness, tot_clean, xerr=hardness_err, yerr=tot_err_clean, fmt='o', markersize=3, alpha=0.5, ecolor='lightgray')\\n\",\n",
    "    \"ax2.set_xlabel('Hardness Ratio (2-10 keV / 0.5-2 keV)', fontsize=14)\\n\",\n",
    "    \"ax2.set_ylabel('Total Count Rate (counts/s)', fontsize=14)\\n\",\n",
    "    \"ax2.set_title('Hardness-Intensity Diagram (HID)')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig(f\\\"{project_root}/products/{obsid}/pn/lc/hid_diagram.png\\\", dpi=300)\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
    " \"metadata\": {\n",
    "  \"kernelspec\": {\n",
    "   \"display_name\": \"Python 3\",\n",
    "   \"language\": \"python\",\n",
    "   \"name\": \"python3\"\n",
    "  },\n",
